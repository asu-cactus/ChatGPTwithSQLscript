    "user_id" TEXT,
    "time" TEXT,
    "bet" TEXT,
    "win" TEXT
);

-- Load data from the CSV file into the source table
COPY "Source1_93_0" FROM 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_93\test_0.csv' WITH (FORMAT csv, HEADER true, NULL 'nan');

-- Drop the target table if it exists
DROP TABLE IF EXISTS "Target1_93";

-- Create the target table with the appropriate data types
CREATE TABLE "Target1_93" (
    "user_id" TEXT,
    "time" TEXT,
    "bet" TEXT,
    "win" TEXT
);

-- Insert data into the target table from the source table
-- Assuming that the user_id needs to be extracted from the string and the time needs to be cleaned from brackets
INSERT INTO "Target1_93" ("user_id", "time", "bet", "win")
SELECT
    SUBSTRING("user_id", 'user_\d+'), -- Extract the user_id pattern
    TRIM("time", '[]'), -- Remove the square brackets from the time
    "bet",
