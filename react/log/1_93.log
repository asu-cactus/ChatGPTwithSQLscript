-- Drop the source table if it exists
DROP TABLE IF EXISTS "Source1_93_0";

-- Create the source table with appropriate data types
CREATE TABLE "Source1_93_0" (
    "user_id" TEXT,
    "time" TEXT,
    "bet" TEXT,
    "win" TEXT
);

-- Load data from CSV into the source table
COPY "Source1_93_0" FROM 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_93\test_0.csv' WITH (FORMAT csv, HEADER true, NULL 'nan');

-- Drop the target table if it exists
DROP TABLE IF EXISTS "Target1_93";

-- Create the target table with appropriate data types
CREATE TABLE "Target1_93" (
    "user_id" TEXT,
    "time" TEXT,
    "bet" TEXT,
    "win" TEXT
);

-- Insert data into the target table with transformation
INSERT INTO "Target1_93" ("user_id", "time", "bet", "win")
SELECT
    -- Extract user_id from the string 'Запись пользователя № - user_xxx'
    SUBSTRING("user_id", 'user_[0-9]+') AS "user_id",
    -- Remove the square brackets from the time field
    TRIM("time", '[]') AS "time",
    "bet",
    "win"
FROM "Source1_93_0";

-- Copy the result into a CSV file
COPY (SELECT * FROM "Target1_93") TO 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_93\Target1_93_result.csv' WITH CSV HEADER;


