-- Drop the source table if it exists
DROP TABLE IF EXISTS "Source1_90_0";

-- Create the source table with appropriate data types and handling of date formats
CREATE TABLE "Source1_90_0" (
    "tweet_id" BIGINT,
    "in_reply_to_status_id" FLOAT,
    "in_reply_to_user_id" FLOAT,
    "timestamp" TIMESTAMP WITH TIME ZONE,
    "source" TEXT,
    "text" TEXT,
    "retweeted_status_id" FLOAT,
    "retweeted_status_user_id" FLOAT,
    "retweeted_status_timestamp" TIMESTAMP WITH TIME ZONE,
    "expanded_urls" TEXT,
    "rating_numerator" INTEGER,
    "rating_denominator" INTEGER,
    "name" TEXT,
    "doggo" TEXT,
    "floofer" TEXT,
    "pupper" TEXT,
    "puppo" TEXT
);

-- Load data from CSV, treating empty values as NULL and correctly handling date formats
COPY "Source1_90_0"
FROM 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_90\test_0.csv'
WITH (FORMAT csv, HEADER true, NULL 'nan');

-- Drop the target table if it exists
DROP TABLE IF EXISTS "Target1_90";

-- Create the target table
CREATE TABLE "Target1_90" (
    "dog_type" TEXT,
    "count" INTEGER
);

-- Insert transformed data into the target table
INSERT INTO "Target1_90" ("dog_type", "count")
SELECT
    CASE
        WHEN "doggo" IS NOT NULL THEN 'doggo'
        WHEN "floofer" IS NOT NULL THEN 'floofer'
        WHEN "pupper" IS NOT NULL THEN 'pupper'
        WHEN "puppo" IS NOT NULL THEN 'puppo'
        ELSE 'None'
    END AS "dog_type",
    COUNT(*) AS "count"
FROM "Source1_90_0"
GROUP BY "dog_type";

-- Copy the result into a CSV file
COPY (SELECT * FROM "Target1_90")
TO 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_90\Target1_90_result.csv'
WITH CSV HEADER;


