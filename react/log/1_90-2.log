-- Drop the existing source table if it exists
DROP TABLE IF EXISTS "Source1_90_0";

-- Create the source table with appropriate data types
CREATE TABLE "Source1_90_0" (
    "tweet_id" BIGINT,
    "in_reply_to_status_id" BIGINT,
    "in_reply_to_user_id" BIGINT,
    "timestamp" TIMESTAMP,
    "source" TEXT,
    "text" TEXT,
    "retweeted_status_id" BIGINT,
    "retweeted_status_user_id" BIGINT,
    "retweeted_status_timestamp" TIMESTAMP,
    "expanded_urls" TEXT,
    "rating_numerator" INTEGER,
    "rating_denominator" INTEGER,
    "name" TEXT,
    "doggo" TEXT,
    "floofer" TEXT,
    "pupper" TEXT,
    "puppo" TEXT
);

-- Load data from CSV file into the source table
COPY "Source1_90_0" FROM 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_90\test_0.csv' WITH (FORMAT csv, HEADER true, NULL 'nan');

-- Drop the existing target table if it exists
DROP TABLE IF EXISTS "Target1_90";

-- Create the target table
CREATE TABLE "Target1_90" (
    "dog_type" TEXT,
    "count" INTEGER
);

-- Insert transformed data into the target table
INSERT INTO "Target1_90" ("dog_type", "count")
SELECT
    CASE
        WHEN "doggo" IS NOT NULL AND "doggo" <> '' THEN 'doggo'
        WHEN "floofer" IS NOT NULL AND "floofer" <> '' THEN 'floofer'
        WHEN "pupper" IS NOT NULL AND "pupper" <> '' THEN 'pupper'
        WHEN "puppo" IS NOT NULL AND "puppo" <> '' THEN 'puppo'
        ELSE 'None'
    END AS "dog_type",
    COUNT(*) AS "count"
FROM "Source1_90_0"
GROUP BY "dog_type";

-- Copy the result into a CSV file
COPY (SELECT * FROM "Target1_90") TO 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_90\Target1_90_result.csv' WITH CSV HEADER;



