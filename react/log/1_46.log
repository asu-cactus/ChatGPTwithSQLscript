-- Drop the existing source table if it exists
DROP TABLE IF EXISTS "Source1_46_0";

-- Create the source table with appropriate data types
CREATE TABLE "Source1_46_0" (
    "Text Date" TEXT,
    "Value Date" TEXT,
    "Zip Code" TEXT,
    "Water Use" DECIMAL,
    "Power Use" DECIMAL
);

-- Load data from CSV into the source table
COPY "Source1_46_0" FROM 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_46\test_0.csv' WITH (FORMAT csv, HEADER true, NULL '');

-- Drop the existing target table if it exists
DROP TABLE IF EXISTS "Target1_46";

-- Create the target table with appropriate data types
CREATE TABLE "Target1_46" (
    "Date" TEXT,
    "Water Use" DECIMAL,
    "Power Use" DECIMAL
);

-- Insert transformed data into the target table
INSERT INTO "Target1_46" ("Date", "Water Use", "Power Use")
SELECT
    TO_CHAR(TO_DATE("Value Date", 'Mon-YY'), 'Mon_YYYY') AS "Date",
    SUM("Water Use") AS "Water Use",
    SUM("Power Use") AS "Power Use"
FROM "Source1_46_0"
GROUP BY TO_CHAR(TO_DATE("Value Date", 'Mon-YY'), 'Mon_YYYY');

-- Copy the result into a CSV file
COPY (SELECT * FROM "Target1_46") TO 'C:\PycharmProjects\ChatGPTwithSQLscript\react\github-pipelines\length1_46\Target1_46_result.csv' WITH CSV HEADER;


